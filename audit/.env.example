# Canvas LMS API bearer token
# Generate one at: https://franciscan.instructure.com/profile/settings → "New Access Token"
ACCESS_TOKEN_EL=your_canvas_api_token_here
CANVAS_BASE_URL={your institution's canvas url here, e.g. https://franciscan.instructure.com}
CANVAS_ACCOUNT_ID=root_account_id_here or sub-account with access to needed courses