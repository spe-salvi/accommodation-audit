    "entry": {
      "title": "Question",
      "item_body": "<div><span style=\"font-family: 'Arial','sans-serif';\">According to Veritatis splendor, those who live by the flesh experience God’s law as a burden, and indeed as a denial or at least a restriction of their own freedom, while those who are impelled by love and walk by the Spirit find in God’s law the fundamental and necessary way in which to practice love as something freely chosen and freely lived out.</span></div>",
      "calculator_type": "none",
      "interaction_data": {
        "choices": [
          {
            "id": "f791aabf-5856-4383-938c-e59de0a90101",
            "position": 1,
            "item_body": "True"
          },
          {
            "id": "309eb3b0-6080-4bd6-9caa-63fdee35641c",
